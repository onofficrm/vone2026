# 홈만 정적 랜딩 우선. 하위 디렉터리(/adm, /bbs 등)는 자체 DirectoryIndex 사용
DirectoryIndex home.page index.php index.html

<IfModule mod_mime.c>
  AddType text/html .page
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # 루트(/)만 home.page — /adm 등 하위 경로는 건드리지 않음
  RewriteRule ^$ /home.page [L]

  # 이미 존재하는 파일/디렉터리는 그대로 (adm, bbs, plugin …)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SEO 독립 URL → 정적 .page
  RewriteRule ^about/?$ /about.page [L]
  RewriteRule ^cars/?$ /cars.page [L]
  RewriteRule ^simulator/?$ /simulator.page [L]
  RewriteRule ^delivery/?$ /delivery.page [L]
  RewriteRule ^guide/?$ /guide.page [L]
  RewriteRule ^reviews/?$ /reviews.page [L]
  RewriteRule ^faq/?$ /faq.page [L]
  RewriteRule ^contact/?$ /contact.page [L]
  RewriteRule ^status/?$ /status.page [L]
  RewriteRule ^process/?$ /process.page [L]
  RewriteRule ^funds/?$ /funds.page [L]
  RewriteRule ^privacy/?$ /privacy.page [L]
  RewriteRule ^documents/?$ /documents.page [L]
</IfModule>
